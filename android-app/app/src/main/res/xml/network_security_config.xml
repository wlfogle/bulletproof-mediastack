<?xml version="1.0" encoding="utf-8"?>
<!--
  Allow cleartext HTTP to the homelab subnet (192.168.12.x).
  All LAN traffic is private — no public cleartext.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- bulletproof-mediastack (post-*arr) — CT-300 holds the whole pipeline -->
        <!-- CT-300 mediastack (Riven UI :3000, Riven API :8080, Jellyfin :8096, Caddy :80/:443) -->
        <domain includeSubdomains="false">192.168.12.30</domain>
        <!-- CT-104 vaultwarden (HTTPS, kept for password manager) -->
        <domain includeSubdomains="false">192.168.12.104</domain>
        <!-- CT-107 authentik (SSO) -->
        <domain includeSubdomains="false">192.168.12.107</domain>
        <!-- CT-100 wireguard (server, optional admin) -->
        <domain includeSubdomains="false">192.168.12.100</domain>
        <!-- Bahamut: AdGuard, wg-easy, Vaultwarden mirror -->
        <domain includeSubdomains="false">192.168.12.244</domain>
        <!-- Proxmox host (admin UI) -->
        <domain includeSubdomains="false">192.168.12.242</domain>
        <!-- Open WebUI / SearXNG when CT-900 is up -->
        <domain includeSubdomains="false">192.168.12.250</domain>
        <!-- Laptop (Sunshine, NFS, etc.) -->
        <domain includeSubdomains="false">192.168.12.172</domain>
        <!-- *.mediastack.lan via Caddy internal CA -->
        <domain includeSubdomains="true">mediastack.lan</domain>
        <!-- DuckDNS -->
        <domain includeSubdomains="true">lou-fogle-media-stack.duckdns.org</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
