auto vmbr1
iface vmbr1 inet manual
    bridge-ports none
    bridge-stp off
    bridge-fd 0
    bridge-multicast-snooping 0
	dns-nameservers 192.168.12.244 1.1.1.1
    # OpenWrt VM internal LAN — no physical port, virtual only
    # CTs/VMs on this bridge get DHCP from OpenWrt (10.10.0.0/24)

auto vmbr2
iface vmbr2 inet manual
    bridge-ports enx00e04c3f4188
    bridge-stp off
    bridge-fd 0
    bridge-multicast-snooping 0
    # UE300 USB NIC -- physical OpenWrt LAN bridge to Archer switch
