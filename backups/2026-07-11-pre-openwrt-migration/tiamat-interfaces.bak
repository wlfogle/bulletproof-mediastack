auto lo
iface lo inet loopback

iface enp4s0 inet manual

auto vmbr0
iface vmbr0 inet static
	address 192.168.12.242/24
	gateway 192.168.12.1
	bridge-ports enp4s0
	bridge-stp off
	bridge-fd 0
	bridge-multicast-snooping 0
	dns-nameservers 192.168.12.244 1.1.1.1

iface wlp6s0 inet manual


source /etc/network/interfaces.d/*

post-up ip neigh replace 192.168.12.225 dev vmbr0 lladdr BC:24:11:2A:83:BB nud permanent
post-up ip neigh replace 192.168.12.230 dev vmbr0 lladdr BC:24:11:E4:51:2C nud permanent

# Static ARP — all critical CTs, auto-set on every vmbr0 up
	post-up ip neigh replace 192.168.12.100 dev vmbr0 lladdr BC:24:11:C1:B5:F4 nud permanent
	post-up ip neigh replace 192.168.12.101 dev vmbr0 lladdr BC:24:11:C3:34:8B nud permanent
