arch: amd64
cores: 6
features: nesting=1,keyctl=1,fuse=1
hostname: mediastack
memory: 12288
mp0: /mnt/hdd/media,mp=/data/media
mp1: /root/Downloads,mp=/root/Downloads
nameserver: 8.8.8.8 1.1.1.1
net0: name=eth0,bridge=vmbr0,gw=192.168.12.1,hwaddr=BC:24:11:E3:7C:DB,ip=192.168.12.30/24,type=veth
onboot: 1
ostype: debian
rootfs: local-lvm:vm-300-disk-0,size=64G
swap: 4096
lxc.cgroup2.devices.allow: c 10:229 rwm
lxc.mount.entry: /dev/fuse dev/fuse none bind,create=file
lxc.cgroup2.devices.allow: c 10:200 rwm
lxc.mount.entry: /dev/net/tun dev/net/tun none bind,create=file
lxc.apparmor.profile: unconfined
lxc.cap.drop: 
lxc.cap.drop: 
lxc.cgroup2.devices.allow: c 226:0 rwm
lxc.cgroup2.devices.allow: c 226:128 rwm
lxc.mount.entry: /dev/dri/card0 dev/dri/card0 none bind,optional,create=file
lxc.mount.entry: /dev/dri/renderD128 dev/dri/renderD128 none bind,optional,create=file
arch: amd64
cores: 2
features: keyctl=1,nesting=1
hostname: alexa-media-bridge
memory: 512
nameserver: 1.1.1.1
net0: name=eth0,bridge=vmbr0,firewall=1,gw=192.168.12.1,hwaddr=BC:24:11:30:1C:C2,ip=192.168.12.201/24,type=veth
ostype: debian
rootfs: hdd-ct:200/vm-200-disk-0.raw,size=16G
swap: 512
unprivileged: 1
