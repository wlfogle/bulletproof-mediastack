# Copy to .env and fill in. .env is gitignored.

# Real-Debrid API token — get yours from https://real-debrid.com/apitoken
RD_API_TOKEN=

# Timezone (any IANA tz like America/New_York, Europe/Berlin)
TZ=America/New_York

# Optional overrides for the deploy script (defaults shown)
# CTID=300
# HOSTNAME=mediastack
# IP=192.168.12.30/24
# GATEWAY=192.168.12.1
# STORAGE=local-lvm
# ROOTFS_GB=16
# RAM_MB=4096
# CORES=4
# FORCE_RECREATE=0
